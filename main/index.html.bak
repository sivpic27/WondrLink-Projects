<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>WondrLink - Your Cancer Care Guide</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #1e40af;
            --primary-light: #3b82f6;
            --primary-lighter: #60a5fa;
            --accent: #0ea5e9;
            --success: #10b981;
            --danger: #ef4444;
            --danger-hover: #dc2626;
            --background: #f8fafc;
            --surface: #ffffff;
            --border: #e2e8f0;
            --border-hover: #cbd5e1;
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --text-muted: #94a3b8;
            --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            --radius: 12px;
            --radius-lg: 16px;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
            background: var(--background);
            color: var(--text-primary);
            height: 100vh;
            overflow: hidden;
            -webkit-font-smoothing: antialiased;
        }

        .app {
            display: flex;
            height: 100vh;
            gap: 20px;
            padding: 20px;
            max-width: 1600px;
            margin: 0 auto;
        }

        /* Sidebar */
        .sidebar {
            width: 340px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            display: flex;
            flex-direction: column;
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .brand-section {
            padding: 24px;
            border-bottom: 1px solid var(--border);
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        }

        .brand-main {
            font-size: 24px;
            font-weight: 700;
            color: white;
            letter-spacing: -0.02em;
        }

        .brand-sub {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.8);
            margin-top: 4px;
        }

        .sidebar-content {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        /* Section Cards */
        .section-card {
            background: var(--background);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 16px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

        .section-title {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .section-badge {
            font-size: 11px;
            color: var(--text-muted);
            background: var(--surface);
            padding: 4px 8px;
            border-radius: 6px;
            font-weight: 500;
        }

        /* Settings Slider */
        .slider-container {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .response-slider {
            width: 100%;
            height: 6px;
            border-radius: 3px;
            background: var(--border);
            outline: none;
            -webkit-appearance: none;
            cursor: pointer;
        }

        .response-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: var(--primary);
            cursor: pointer;
            border: 3px solid white;
            box-shadow: var(--shadow);
        }

        .slider-labels {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            color: var(--text-muted);
        }

        .current-setting {
            text-align: center;
            font-size: 12px;
            font-weight: 600;
            color: var(--primary);
            padding: 6px 12px;
            background: rgba(59, 130, 246, 0.1);
            border-radius: 6px;
            margin-top: 4px;
        }

        /* Upload Area */
        .upload-area {
            margin-top: 4px;
        }

        .upload-placeholder {
            border: 2px dashed var(--border);
            border-radius: var(--radius);
            padding: 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
            background: var(--surface);
        }

        .upload-placeholder:hover {
            border-color: var(--primary-lighter);
            background: rgba(59, 130, 246, 0.02);
        }

        .upload-icon {
            font-size: 28px;
            margin-bottom: 8px;
        }

        .upload-text {
            font-size: 13px;
            color: var(--text-secondary);
            font-weight: 500;
        }

        .upload-hint {
            font-size: 11px;
            color: var(--text-muted);
            margin-top: 4px;
        }

        /* Profile Info */
        .profile-info {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .profile-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 10px;
            background: var(--surface);
            border-radius: 6px;
            font-size: 12px;
        }

        .profile-label {
            color: var(--text-muted);
            font-weight: 500;
        }

        .profile-value {
            color: var(--text-primary);
            font-weight: 500;
            text-align: right;
        }

        /* Buttons */
        button {
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 8px;
            padding: 10px 16px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 13px;
        }

        button:hover {
            background: var(--primary-light);
        }

        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        button.secondary {
            background: var(--background);
            color: var(--text-secondary);
            border: 1px solid var(--border);
        }

        button.secondary:hover {
            background: var(--border);
        }

        button.danger {
            background: var(--danger);
        }

        button.danger:hover {
            background: var(--danger-hover);
        }

        button.small {
            padding: 6px 12px;
            font-size: 12px;
        }

        /* Data Sources List */
        .data-sources-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
            max-height: 200px;
            overflow-y: auto;
        }

        .data-source-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 12px;
        }

        .data-source-icon {
            width: 32px;
            height: 32px;
            background: rgba(59, 130, 246, 0.1);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
        }

        .data-source-info {
            flex: 1;
            min-width: 0;
        }

        .data-source-name {
            font-weight: 500;
            color: var(--text-primary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .data-source-meta {
            font-size: 11px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .no-data {
            text-align: center;
            padding: 20px;
            color: var(--text-muted);
            font-size: 13px;
        }

        /* Status Bar */
        .status-bar {
            padding: 12px 16px;
            background: var(--background);
            border-top: 1px solid var(--border);
            font-size: 12px;
            color: var(--text-muted);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .status-indicator {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--success);
        }

        .status-dot.inactive {
            background: var(--text-muted);
        }

        /* Chat Area */
        .chat-wrap {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .chat-header {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 20px 24px;
            margin-bottom: 16px;
            box-shadow: var(--shadow-sm);
        }

        .chat-title {
            font-size: 20px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .chat-subtitle {
            font-size: 14px;
            color: var(--text-secondary);
            margin-top: 4px;
        }

        .messages {
            flex: 1;
            overflow-y: auto;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 24px;
            margin-bottom: 16px;
            box-shadow: var(--shadow-sm);
        }

        .input-section {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 16px;
            display: flex;
            gap: 12px;
            align-items: flex-end;
            box-shadow: var(--shadow-sm);
        }

        textarea {
            flex: 1;
            min-height: 48px;
            max-height: 120px;
            resize: none;
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 12px 16px;
            font-family: inherit;
            font-size: 14px;
            color: var(--text-primary);
            background: var(--background);
            outline: none;
            transition: border-color 0.2s;
            line-height: 1.5;
        }

        textarea:focus {
            border-color: var(--primary-lighter);
        }

        textarea::placeholder {
            color: var(--text-muted);
        }

        .send-btn {
            height: 48px;
            min-width: 80px;
            font-weight: 600;
        }

        /* Messages */
        .msg {
            margin-bottom: 20px;
            display: flex;
            flex-direction: column;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .msg.user {
            align-items: flex-end;
        }

        .bubble {
            max-width: 75%;
            padding: 14px 18px;
            border-radius: var(--radius);
            font-size: 14px;
            line-height: 1.6;
        }

        .bubble.user {
            background: var(--primary);
            color: white;
            border-bottom-right-radius: 4px;
        }

        .bubble.bot {
            background: var(--background);
            color: var(--text-primary);
            border: 1px solid var(--border);
            border-bottom-left-radius: 4px;
        }

        .ai-status {
            font-size: 11px;
            color: var(--text-muted);
            margin-top: 6px;
            padding: 4px 10px;
            background: var(--background);
            border-radius: 4px;
            display: inline-block;
        }

        .ai-status.enhanced {
            color: var(--primary);
            background: rgba(59, 130, 246, 0.1);
        }

        /* Loading */
        .loading {
            display: inline-block;
            width: 14px;
            height: 14px;
            border: 2px solid var(--border);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 3px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--border-hover);
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .app {
                flex-direction: column;
                overflow-y: auto;
            }

            .sidebar {
                width: 100%;
            }

            .chat-wrap {
                min-height: 60vh;
            }
        }

        /* Auth Modal */
        .auth-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(15, 23, 42, 0.8);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .auth-modal {
            background: var(--surface);
            border-radius: var(--radius-lg);
            padding: 32px;
            width: 100%;
            max-width: 400px;
            box-shadow: var(--shadow-lg);
        }

        .auth-title {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-primary);
            text-align: center;
            margin-bottom: 8px;
        }

        .auth-subtitle {
            font-size: 14px;
            color: var(--text-secondary);
            text-align: center;
            margin-bottom: 24px;
        }

        .auth-form {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .auth-input {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 14px;
            outline: none;
            transition: border-color 0.2s;
        }

        .auth-input:focus {
            border-color: var(--primary-lighter);
        }

        .auth-btn {
            width: 100%;
            padding: 12px;
            font-size: 14px;
            font-weight: 600;
        }

        .auth-toggle {
            text-align: center;
            margin-top: 16px;
            font-size: 13px;
            color: var(--text-secondary);
        }

        .auth-toggle a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 500;
            cursor: pointer;
        }

        .auth-toggle a:hover {
            text-decoration: underline;
        }

        .auth-error {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
            padding: 10px 12px;
            border-radius: 6px;
            font-size: 13px;
            display: none;
        }

        .user-info {
            margin-bottom: 16px;
        }

        .logout-btn {
            width: 100%;
            padding: 10px 16px;
            font-size: 13px;
            background: var(--background);
            color: var(--text-secondary);
            border: 1px solid var(--border);
            border-radius: 8px;
            cursor: pointer;
        }

        .logout-btn:hover {
            background: var(--danger);
            color: white;
            border-color: var(--danger);
        }

        .logout-btn #userName {
            color: var(--text-primary);
            font-weight: 500;
        }

        .logout-btn:hover #userName {
            color: white;
        }
    </style>
</head>

<body>
    <!-- Auth Modal -->
    <div class="auth-overlay" id="authOverlay">
        <div class="auth-modal">
            <div class="auth-title" id="authTitle">Welcome Back</div>
            <div class="auth-subtitle" id="authSubtitle">Sign in to access your cancer care guide</div>
            <div class="auth-error" id="authError"></div>
            <form class="auth-form" id="authForm">
                <input type="text" class="auth-input" id="authUsername" placeholder="Username" required minlength="3">
                <input type="password" class="auth-input" id="authPassword" placeholder="Password" required minlength="4">
                <button type="submit" class="auth-btn" id="authSubmitBtn">Sign In</button>
            </form>
            <div class="auth-toggle">
                <span id="authToggleText">Don't have an account?</span>
                <a id="authToggleLink" onclick="toggleAuthMode()">Create one</a>
            </div>
        </div>
    </div>

    <div class="app" id="mainApp" style="display: none;">
        <div class="sidebar">
            <div class="brand-section">
                <div class="brand-main">WondrLink</div>
                <div class="brand-sub">Your AI Cancer Care Guide</div>
            </div>

            <div class="sidebar-content">
                <!-- User Info -->
                <div class="user-info" id="userInfo">
                    <button class="logout-btn" onclick="handleLogout()"><span id="userName">User</span> · Logout</button>
                </div>
                <!-- Response Settings -->
                <div class="section-card">
                    <div class="section-header">
                        <div class="section-title">Response Detail</div>
                    </div>
                    <div class="slider-container">
                        <input type="range" min="0" max="2" value="1" step="1" class="response-slider" id="responseLength">
                        <div class="slider-labels">
                            <span>Brief</span>
                            <span>Normal</span>
                            <span>Detailed</span>
                        </div>
                        <div class="current-setting" id="currentSetting">Normal responses</div>
                    </div>
                </div>

                <!-- Patient Profile -->
                <div class="section-card">
                    <div class="section-header">
                        <div class="section-title">Patient Profile</div>
                        <div class="section-badge" id="profileBadge">No profile</div>
                    </div>

                    <!-- Upload area (shown when no profile) -->
                    <div class="upload-area" id="uploadArea">
                        <input type="file" id="profileFile" accept=".json" hidden />
                        <div class="upload-placeholder" onclick="document.getElementById('profileFile').click()">
                            <div class="upload-icon">📋</div>
                            <div class="upload-text">Click to upload patient profile</div>
                            <div class="upload-hint">JSON format</div>
                        </div>
                    </div>

                    <!-- Profile info (shown after upload) -->
                    <div class="profile-info" id="profileInfo" style="display: none;"></div>

                    <!-- Clear button -->
                    <button class="small secondary" id="clearProfileBtn" style="display: none; margin-top: 12px; width: 100%;">Clear Profile</button>
                </div>

                <!-- Data Sources -->
                <div class="section-card">
                    <div class="section-header">
                        <div class="section-title">Medical Guidelines</div>
                        <div class="section-badge" id="documentCount">0 sources</div>
                    </div>
                    <div class="data-sources-list" id="dataSourcesList">
                        <div class="no-data">No data sources available</div>
                    </div>
                </div>
            </div>

            <div class="status-bar">
                <div class="status-indicator">
                    <div class="status-dot" id="statusDot"></div>
                    <span id="aiStatus">Ready</span>
                </div>
                <span id="chunkCount">0 chunks</span>
            </div>
        </div>

        <div class="chat-wrap">
            <div class="chat-header">
                <div class="chat-title">Your Cancer Care Guide</div>
                <div class="chat-subtitle">Ask questions and get evidence-based guidance in plain language</div>
            </div>

            <div class="messages" id="messages">
                <div class="msg bot">
                    <div class="bubble bot">
                        <strong>Welcome to WondrLink!</strong><br><br>
                        I'm here to help you understand your cancer treatment in simple, everyday language.<br><br>
                        <strong>I can help you:</strong><br>
                        - Understand your diagnosis and treatment options<br>
                        - Explain medical terms in plain English<br>
                        - Answer questions about side effects<br>
                        - Help you prepare for appointments<br><br>
                        <em>Upload your patient profile in the sidebar, then ask me anything.</em>
                    </div>
                </div>
            </div>

            <div class="input-section">
                <textarea id="msgInput" placeholder="Ask me anything about your treatment..."></textarea>
                <button id="sendBtn" class="send-btn">Send</button>
            </div>
        </div>
    </div>

    <script>
        const sessionId = 'session_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);

        // Auth state
        let isLoginMode = true;
        let currentUser = null;

        // Auth DOM elements
        const authOverlay = document.getElementById("authOverlay");
        const authTitle = document.getElementById("authTitle");
        const authSubtitle = document.getElementById("authSubtitle");
        const authError = document.getElementById("authError");
        const authForm = document.getElementById("authForm");
        const authUsername = document.getElementById("authUsername");
        const authPassword = document.getElementById("authPassword");
        const authSubmitBtn = document.getElementById("authSubmitBtn");
        const authToggleText = document.getElementById("authToggleText");
        const authToggleLink = document.getElementById("authToggleLink");
        const mainApp = document.getElementById("mainApp");
        const userInfo = document.getElementById("userInfo");
        const userName = document.getElementById("userName");

        // Toggle between login and register modes
        function toggleAuthMode() {
            isLoginMode = !isLoginMode;
            authError.textContent = "";
            authError.style.display = "none";

            if (isLoginMode) {
                authTitle.textContent = "Welcome Back";
                authSubtitle.textContent = "Sign in to access your cancer care guide";
                authSubmitBtn.textContent = "Sign In";
                authToggleText.textContent = "Don't have an account?";
                authToggleLink.textContent = "Create one";
            } else {
                authTitle.textContent = "Create Account";
                authSubtitle.textContent = "Get personalized cancer care guidance";
                authSubmitBtn.textContent = "Create Account";
                authToggleText.textContent = "Already have an account?";
                authToggleLink.textContent = "Sign in";
            }
        }

        // Show auth error
        function showAuthError(message) {
            authError.textContent = message;
            authError.style.display = "block";
        }

        // Check authentication status on page load
        async function checkAuth() {
            try {
                const resp = await fetch("/auth/me");
                if (resp.ok) {
                    const data = await resp.json();
                    // Check if actually authenticated (not just HTTP 200)
                    if (data.authenticated && data.user) {
                        currentUser = data.user;
                        showMainApp();
                        return true;
                    }
                }
            } catch (e) {
                console.log("Not authenticated");
            }
            showAuthModal();
            return false;
        }

        // Show the main app
        function showMainApp() {
            authOverlay.style.display = "none";
            mainApp.style.display = "flex";
            if (currentUser) {
                userName.textContent = currentUser.username;
            }
        }

        // Show the auth modal
        function showAuthModal() {
            mainApp.style.display = "none";
            authOverlay.style.display = "flex";
            authUsername.value = "";
            authPassword.value = "";
            authError.style.display = "none";
        }

        // Handle auth form submission
        authForm.addEventListener("submit", async (e) => {
            e.preventDefault();

            const username = authUsername.value.trim();
            const password = authPassword.value;

            if (!username || !password) {
                showAuthError("Please fill in all fields");
                return;
            }

            authSubmitBtn.disabled = true;
            authSubmitBtn.textContent = isLoginMode ? "Signing in..." : "Creating account...";

            try {
                const endpoint = isLoginMode ? "/auth/login" : "/auth/register";
                const resp = await fetch(endpoint, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ username, password })
                });

                const data = await resp.json();

                if (resp.ok) {
                    currentUser = { user_id: data.user_id, username: data.username };
                    showMainApp();
                    // Load data after successful auth
                    await loadDataSources();
                    // Check for existing profile
                    try {
                        const profileResp = await fetch("/get_patient");
                        if (profileResp.ok) {
                            const profileData = await profileResp.json();
                            if (profileData.profile && profileData.context) {
                                displayProfile(profileData.context, profileData.patient_summary);
                            }
                        }
                    } catch (err) {
                        console.log("No existing profile");
                    }
                } else {
                    showAuthError(data.error || "Authentication failed");
                }
            } catch (err) {
                showAuthError("Network error. Please try again.");
            } finally {
                authSubmitBtn.disabled = false;
                authSubmitBtn.textContent = isLoginMode ? "Sign In" : "Create Account";
            }
        });

        // Handle logout
        async function handleLogout() {
            try {
                await fetch("/auth/logout", { method: "POST" });
            } catch (e) {
                console.error("Logout error:", e);
            }
            currentUser = null;
            // Reset profile state
            uploadArea.style.display = "block";
            profileInfo.style.display = "none";
            clearProfileBtn.style.display = "none";
            profileBadge.textContent = "No profile";
            profileBadge.style.background = "";
            profileBadge.style.color = "";
            // Clear chat
            messages.innerHTML = "";
            showAuthModal();
        }

        // DOM Elements
        const chunkCount = document.getElementById("chunkCount");
        const aiStatus = document.getElementById("aiStatus");
        const statusDot = document.getElementById("statusDot");
        const sendBtn = document.getElementById("sendBtn");
        const msgInput = document.getElementById("msgInput");
        const messages = document.getElementById("messages");
        const responseSlider = document.getElementById("responseLength");
        const currentSetting = document.getElementById("currentSetting");
        const dataSourcesList = document.getElementById("dataSourcesList");
        const documentCount = document.getElementById("documentCount");

        // Profile elements
        const profileFile = document.getElementById("profileFile");
        const uploadArea = document.getElementById("uploadArea");
        const profileInfo = document.getElementById("profileInfo");
        const profileBadge = document.getElementById("profileBadge");
        const clearProfileBtn = document.getElementById("clearProfileBtn");

        // Profile upload handler
        profileFile.addEventListener("change", async (e) => {
            const file = e.target.files[0];
            if (!file) return;

            const form = new FormData();
            form.append("file", file);

            try {
                uploadArea.querySelector('.upload-placeholder').innerHTML = '<div class="loading"></div> Loading...';

                const resp = await fetch("/upload_profile", { method: "POST", body: form });
                const data = await resp.json();

                if (resp.ok) {
                    displayProfile(data.context, data.patient_summary);
                } else {
                    alert("Upload failed: " + (data.error || "Unknown error"));
                    resetUploadArea();
                }
            } catch (err) {
                alert("Network error: " + err.message);
                resetUploadArea();
            }
        });

        function displayProfile(context, summary) {
            uploadArea.style.display = "none";
            profileInfo.style.display = "flex";
            clearProfileBtn.style.display = "block";
            profileBadge.textContent = "Active";
            profileBadge.style.background = "rgba(16, 185, 129, 0.1)";
            profileBadge.style.color = "#10b981";

            // Helper to calculate age from birthdate
            function calcAge(dateStr) {
                if (!dateStr) return null;
                const birth = new Date(dateStr);
                if (isNaN(birth)) return null;
                const today = new Date();
                let age = today.getFullYear() - birth.getFullYear();
                const m = today.getMonth() - birth.getMonth();
                if (m < 0 || (m === 0 && today.getDate() < birth.getDate())) age--;
                return age;
            }

            // Helper to get current treatment (last one or most recent)
            function getCurrentTreatment(treatments) {
                if (!treatments || !treatments.length) return null;
                // Find one that mentions "Currently" or just take the last one
                const current = treatments.find(t => t.toLowerCase().includes('currently'));
                if (current) {
                    // Extract just the drug name
                    const match = current.match(/Currently on (.+?)(?:\s*\(|$)/i);
                    return match ? match[1].trim() : current.replace(/^Currently on\s*/i, '').split('(')[0].trim();
                }
                // Otherwise take the last treatment
                const last = treatments[treatments.length - 1];
                return last.split('(')[0].trim();
            }

            // Build profile rows from context
            const rows = [];

            if (context.patient_name) {
                rows.push({ label: "Name", value: context.patient_name });
            }

            // Handle age - could be a number or a birthdate
            if (context.age) {
                const ageVal = context.age;
                if (typeof ageVal === 'number') {
                    rows.push({ label: "Age", value: ageVal + " years" });
                } else if (typeof ageVal === 'string' && ageVal.includes('-')) {
                    // It's a date string
                    const age = calcAge(ageVal);
                    if (age) rows.push({ label: "Age", value: age + " years" });
                } else {
                    rows.push({ label: "Age", value: ageVal });
                }
            } else if (context.dob || context.birthdate || context.date_of_birth) {
                const dob = context.dob || context.birthdate || context.date_of_birth;
                const age = calcAge(dob);
                if (age) rows.push({ label: "Age", value: age + " years" });
            }

            if (context.cancer_type) {
                // Shorten long cancer type descriptions
                let diagnosis = context.cancer_type;
                if (diagnosis.length > 40) {
                    diagnosis = diagnosis.split(' ').slice(0, 4).join(' ') + '...';
                }
                rows.push({ label: "Diagnosis", value: diagnosis });
            }

            if (context.stage) {
                rows.push({ label: "Stage", value: context.stage });
            }

            if (context.current_treatments?.length) {
                const treatment = getCurrentTreatment(context.current_treatments);
                if (treatment) {
                    rows.push({ label: "Current Tx", value: treatment });
                }
            }

            if (context.oncologist) {
                rows.push({ label: "Oncologist", value: context.oncologist });
            }

            // Fallback if no structured data
            if (rows.length === 0 && summary) {
                rows.push({ label: "Summary", value: summary });
            }

            profileInfo.innerHTML = rows.map(r => `
                <div class="profile-row">
                    <span class="profile-label">${r.label}</span>
                    <span class="profile-value">${r.value}</span>
                </div>
            `).join('');

            // Shorter status text
            const cancerShort = context.cancer_type?.split(' ')[0] || 'Patient';
            aiStatus.textContent = `${cancerShort} context`;
        }

        function resetUploadArea() {
            uploadArea.querySelector('.upload-placeholder').innerHTML = `
                <div class="upload-icon">📋</div>
                <div class="upload-text">Click to upload patient profile</div>
                <div class="upload-hint">JSON format</div>
            `;
            profileFile.value = '';
        }

        // Clear profile handler
        clearProfileBtn.addEventListener("click", async () => {
            if (!confirm("Clear the patient profile?")) return;

            try {
                await fetch("/clear_profile", { method: "POST" });
                uploadArea.style.display = "block";
                profileInfo.style.display = "none";
                clearProfileBtn.style.display = "none";
                profileBadge.textContent = "No profile";
                profileBadge.style.background = "";
                profileBadge.style.color = "";
                resetUploadArea();
                aiStatus.textContent = "Ready";
            } catch (err) {
                alert("Error: " + err.message);
            }
        });

        // Load data sources
        async function loadDataSources() {
            try {
                const resp = await fetch("/data_sources");
                const j = await resp.json();

                if (resp.ok && j.data_sources) {
                    displayDataSources(j.data_sources);
                    const totalChunks = j.total_chunks || 0;

                    if (totalChunks > 0) {
                        statusDot.classList.remove('inactive');
                        aiStatus.textContent = "Ready";
                        chunkCount.textContent = "Ready";
                    } else {
                        chunkCount.textContent = "Loading...";
                    }
                }
            } catch (e) {
                console.error("Failed to load data sources:", e);
                statusDot.classList.add('inactive');
                chunkCount.textContent = "Error";
            }
        }

        // Display data sources
        function displayDataSources(sources) {
            const totalDocs = sources.length;
            documentCount.textContent = `${totalDocs} ${totalDocs === 1 ? 'source' : 'sources'}`;

            if (totalDocs === 0) {
                dataSourcesList.innerHTML = '<div class="no-data">No data sources available</div>';
                return;
            }

            // Show summary message instead of individual document names
            dataSourcesList.innerHTML = `
                <div class="no-data" style="color: var(--success);">
                    ${totalDocs} document${totalDocs !== 1 ? 's' : ''} chunked and ready
                </div>
            `;
        }

        // Response length handler
        function updateResponseLength() {
            const value = responseSlider.value;
            const settings = {
                "0": "Brief responses",
                "1": "Normal responses",
                "2": "Detailed responses"
            };
            currentSetting.textContent = settings[value];
        }

        responseSlider.addEventListener("input", updateResponseLength);
        updateResponseLength();

        // Chat helpers
        function addMessage(text, who = "bot", metadata = null) {
            const div = document.createElement("div");
            div.className = "msg " + who;

            const bubble = document.createElement("div");
            bubble.className = "bubble " + who;
            bubble.innerHTML = text.replace(/\n/g, '<br>');
            div.appendChild(bubble);

            if (who === "bot" && metadata) {
                const status = document.createElement("div");
                const contextUsed = metadata.patient_context_used;
                const retrievedCount = metadata.retrieved_count || 0;

                let statusText = [];
                if (contextUsed) statusText.push("personalized");
                if (retrievedCount > 0) statusText.push(`${retrievedCount} sources`);

                if (statusText.length) {
                    status.className = "ai-status enhanced";
                    status.textContent = statusText.join(" · ");
                    div.appendChild(status);
                }
            }

            messages.appendChild(div);
            messages.scrollTop = messages.scrollHeight;
        }

        function getResponseLength() {
            return { "0": "brief", "1": "normal", "2": "detailed" }[responseSlider.value];
        }

        sendBtn.addEventListener("click", async () => {
            const msg = msgInput.value.trim();
            if (!msg) return;

            sendBtn.disabled = true;
            addMessage(msg, "user");
            msgInput.value = "";
            msgInput.style.height = "48px";
            addMessage("Thinking...", "bot");

            try {
                const resp = await fetch("/chat", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        message: msg,
                        response_length: getResponseLength(),
                        session_id: sessionId
                    })
                });
                const j = await resp.json();

                // Remove thinking message
                messages.lastChild.remove();

                if (resp.ok) {
                    addMessage(j.answer || "No response", "bot", j);
                } else {
                    addMessage("Error: " + (j.error || "Unknown error"), "bot");
                }
            } catch (e) {
                messages.lastChild.remove();
                addMessage("Network error: " + e.message, "bot");
            } finally {
                sendBtn.disabled = false;
                msgInput.focus();
            }
        });

        // Enter to send
        msgInput.addEventListener("keydown", (e) => {
            if (e.key === "Enter" && !e.shiftKey) {
                e.preventDefault();
                sendBtn.click();
            }
        });

        // Auto-resize textarea
        msgInput.addEventListener("input", function() {
            this.style.height = "48px";
            this.style.height = Math.min(this.scrollHeight, 120) + "px";
        });

        // Load on page load
        window.addEventListener("load", async () => {
            // Check authentication first
            const isAuthed = await checkAuth();
            if (isAuthed) {
                await loadDataSources();

                // Check for existing profile
                try {
                    const resp = await fetch("/get_patient");
                    if (resp.ok) {
                        const data = await resp.json();
                        if (data.profile && data.context) {
                            displayProfile(data.context, data.patient_summary);
                        }
                    }
                } catch (e) {
                    console.log("No existing profile");
                }
            }
        });
    </script>
</body>

</html>
